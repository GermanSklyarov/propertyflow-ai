{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@propertyflow/domain": ["packages/domain/src/index.ts"],
      "@propertyflow/contracts": ["packages/contracts/src/index.ts"],
      "@propertyflow/config": ["packages/config/src/index.ts"]
    }
  }
}

