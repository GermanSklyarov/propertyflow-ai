{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "allowJs": true,
    "baseUrl": ".",
    "declaration": true,
    "emitDeclarationOnly": false,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@entities/*": [
        "src/entities/*"
      ],
      "@propertyflow/config": [
        "../../packages/config/src/index.ts"
      ],
      "@propertyflow/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@propertyflow/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@views/*": [
        "src/views/*"
      ]
    },
    "resolveJsonModule": true
  },
  "include": [
    "next-env.d.ts",
    "next.config.mjs",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "references": [
    {
      "path": "../../packages/contracts"
    }
  ],
  "exclude": [
    "node_modules"
  ]
}
