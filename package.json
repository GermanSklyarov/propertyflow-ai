{
  "name": "propertyflow-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first real estate SaaS for Thailand property search and agency automation.",
  "license": "UNLICENSED",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b",
    "dev": "node scripts/dev.mjs",
    "dev:all": "node scripts/dev.mjs",
    "dev:api": "npm run dev --workspace @propertyflow/api",
    "dev:web": "npm run dev --workspace @propertyflow/web",
    "dev:agency": "npm run dev --workspace @propertyflow/agency",
    "dev:admin": "npm run dev --workspace @propertyflow/admin",
    "dev:worker": "npm run dev --workspace @propertyflow/worker",
    "infra:up": "docker compose up -d postgres redis opensearch minio",
    "infra:down": "docker compose down",
    "migrate": "npm run migrate --workspace @propertyflow/api",
    "format": "prettier --write .",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
